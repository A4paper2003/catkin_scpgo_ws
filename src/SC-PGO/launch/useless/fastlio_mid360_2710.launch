<launch>
   <!-- SC-PGO with GPS-fused odometry from EKF -->
   
   <param name="scan_line" type="int" value="64" />
   
   <!-- remove too closed points -->
   <param name="minimum_range" type="double" value="0.5"/>
   
   <param name="mapping_line_resolution" type="double" value="0.4"/>
   <param name="mapping_plane_resolution" type="double" value="0.8"/>
   <param name="mapviz_filter_size" type="double" value="0.05"/>
   
   <!-- SC-A-LOAM -->
   <param name="keyframe_meter_gap" type="double" value="0.5"/>
   
   <!-- Scan Context -->
   <param name="sc_dist_thres" type="double" value="0.15"/>
   <param name="sc_max_radius" type="double" value="80.0"/>
   
   <!-- for MulRan -->
   <param name="lidar_type" type="string" value="MID-360"/>
   
   <!-- IMPORTANT: Input configuration for GPS-fused system -->
   <!-- SC-PGO reads odometry from EKF (which already fuses FAST-LIO + GPS) -->
   <remap from="/aft_mapped_to_init" to="/odometry/filtered"/>
   
   <!-- Point cloud from FAST-LIO -->
   <remap from="/velodyne_cloud_registered_local" to="/cloud_registered_body"/>
   <remap from="/cloud_for_scancontext" to="/cloud_registered_lidar"/>
   
   <!-- Save directory -->
   <param name="save_directory" type="string" value="/home/uav-fyp/Documents/sc_pgo_results/"/>
   
   <!-- SC-PGO node with additional parameters to prevent TF conflicts -->
   <node pkg="aloam_velodyne" type="alaserPGO_gps" name="alaserPGO_gps" output="screen">
      <!-- Disable TF publishing if SC-PGO has this option -->
      <!-- Some versions allow disabling TF to prevent conflicts -->
      <param name="publish_tf" type="bool" value="true"/>
      
      <!-- Set TF publishing rate if available -->
      <param name="tf_publish_rate" type="double" value="10.0"/>
      
      <!-- Use GPS mode if available in your SC-PGO version -->
      <param name="use_gps" type="bool" value="true"/>
      
      <!-- GPS weight for pose graph optimization -->
      <param name="gps_edge_stddev" type="double" value="1.0"/>
      
      <!-- Ensure unique timestamps -->
      <param name="use_sim_time" type="bool" value="false"/>
   </node>
   
   <!-- Additional TF static publisher if needed for visualization -->
   <!-- Only use if aft_pgo frame is not being published -->
   <!--
   <node pkg="tf2_ros" type="static_transform_publisher" name="aft_pgo_publisher"
         args="0 0 0 0 0 0 camera_init aft_pgo" if="false"/>
   -->
   
   <!-- Visualization -->
   <arg name="rvizscpgo" default="true" />
   <group if="$(arg rvizscpgo)">
       <node launch-prefix="nice" pkg="rviz" type="rviz" name="rvizscpgo" 
             args="-d $(find aloam_velodyne)/rviz_cfg/aloam_velodyne2.rviz" />
   </group>
   
</launch>
