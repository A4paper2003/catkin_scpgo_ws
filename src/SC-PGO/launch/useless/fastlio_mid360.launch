<launch>

    <param name="/use_sim_time" value="true"/>
    
    <param name="scan_line" type="int" value="64" />

    <param name="minimum_range" type="double" value="0.5"/>

    <param name="mapping_line_resolution" type="double" value="0.4"/> <param name="mapping_plane_resolution" type="double" value="0.8"/> <param name="mapviz_filter_size" type="double" value="0.05"/>

    <param name="keyframe_meter_gap" type="double" value="0.5"/>

    <param name="sc_dist_thres" type="double" value="0.15"/> <param name="sc_max_radius" type="double" value="80.0"/> <param name="lidar_type" type="string" value="MID-360"/>

    <remap from="/aft_mapped_to_init" to="/Odometry"/>
    <remap from="/velodyne_cloud_registered_local" to="/cloud_registered_body"/>
    <remap from="/cloud_for_scancontext" to="/cloud_registered_lidar"/>

    <param name="save_directory" type="string" value="/home/uav-fyp/Documents/sc_pgo_results/"/>

    <node pkg="aloam_velodyne" type="alaserPGO_gps" name="alaserPGO_gps" output="screen">
        <remap from="/gps/fix" to="/mavros/global_position/global"/>

        <param name="gps_cov_x" value="0.8"/>  <param name="gps_cov_y" value="0.8"/>  <param name="gps_cov_z" value="1.0"/>  </node>

    <node pkg="topic_tools" type="relay" name="gps_relay"
        args="/mavros/global_position/global /gps/fix"
        output="screen"/>

    <node pkg="rostopic" type="rostopic" name="gps_monitor"
        args="hz /mavros/global_position/global"
        output="screen"/>

    <arg name="rvizscpgo" default="true" />
    <group if="$(arg rvizscpgo)">
        <node launch-prefix="nice" pkg="rviz" type="rviz" name="rvizscpgo" args="-d $(find aloam_velodyne)/rviz_cfg/aloam_velodyne2.rviz" />
    </group>

</launch>

-----------

        <remap from="/gps/fix" to="/mavros/global_position/global"/>
        <param name="gps_cov_x" value="0.8"/>
        <param name="gps_cov_y" value="0.8"/>
        <param name="gps_cov_z" value="1.0"/>

    <node pkg="topic_tools" type="relay" name="gps_relay"
        args="/mavros/global_position/global /gps/fix"
        output="screen"/>
